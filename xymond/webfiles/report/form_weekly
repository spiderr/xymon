<div class="card card-body report-form-weekly xymon-form-card">
  <h5 class="card-title">Xymon Weekly Availability Report</h5>
  <form method="POST" action="&SCRIPT_NAME">
    <input type="hidden" name="type" value="week">
    <div class="d-flex flex-wrap align-items-end xymon-date-row">
      <div>
        <label class="form-label">Week</label>
        <select name="week" class="form-select">&REPWEEKLIST</select>
      </div>
      <div>
        <label class="form-label">Year</label>
        <select name="year" class="form-select">&REPYEARLIST</select>
      </div>
    </div>
    <button type="submit" name="SUB" value="View Report" class="btn btn-primary">View Report</button>
  </form>
</div>
