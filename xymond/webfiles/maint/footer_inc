function updateOptions() {
  var sel = document.getElementById('selectionform').hostname;
  var chosen = [];
  for (var i = 0; i < sel.options.length; i++) {
    if (sel.options[i].selected) chosen.push(sel.options[i].text);
  }
  swapOptions(chosen);
}
function swapOptions(arrayNames) {
  var dt = document.getElementById('selectionform').disabletest;
  while (dt.options.length > 0) dt.options[0] = null;
  var merged = [];
  for (var j = 0; j < arrayNames.length; j++) {
    if (hosts[arrayNames[j]]) merged = merged.concat(hosts[arrayNames[j]]);
  }
  merged = merged.unique();
  for (var i = 0; i < merged.length; i++) dt.options[i] = new Option(merged[i]);
}
function checkRadio(id) {
  var r = document.getElementById(id);
  if (r) r.checked = true;
}
function ispositive(v) {
  var s = v.toString();
  for (var i = 0; i < s.length; i++) { if (s[i] < '0' || s[i] > '9') return false; }
  return parseInt(s, 10) >= 1;
}
function disableButtons(f) {
  for (var i = 0; i < f.elements.length; i++) {
    if (f.elements[i].type.toLowerCase() === 'button') f.elements[i].disabled = true;
  }
}
function validateDisable(theform) {
  if (!theform.hostname.value) {
    alert('You must select the Host(s) to disable!');
    theform.hostname.focus();
    return false;
  }
  if (!theform.disabletest.value) {
    alert('You must select the Test(s) to disable!');
    theform.disabletest.focus();
    return false;
  }
  if (!theform.cause.value) {
    alert('You must fill in the Cause field!');
    theform.cause.focus();
    return false;
  }
  if (theform.go2.value === 'Disable for' && !ispositive(theform.duration.value)) {
    alert('Duration must be a positive integer.');
    return false;
  }
  var idx = theform.hostname.options.selectedIndex;
  if (idx >= 0 && theform.hostname.options[idx].value === 'ALL' &&
      !confirm('Do you really want to disable ALL Hosts? This could take a while.')) {
    return false;
  }
  disableButtons(theform);
  theform.submit();
}
(function() {
  var sentinel = document.getElementById('xymon-maint-filtered');
  if (!sentinel || !sentinel.dataset.active) return;
  var preselectHost = sentinel.dataset.preselecthost || '';
  var preselectTest = sentinel.dataset.preselecttest || '';
  if (preselectHost) {
    var sel = document.getElementById('selectionform').hostname;
    for (var i = 0; i < sel.options.length; i++) {
      if (sel.options[i].text === preselectHost || sel.options[i].value === preselectHost) {
        sel.options[i].selected = true;
        break;
      }
    }
    updateOptions();
    if (preselectTest) {
      var dt = document.getElementById('selectionform').disabletest;
      for (var j = 0; j < dt.options.length; j++) {
        if (dt.options[j].text === preselectTest || dt.options[j].value === preselectTest) {
          dt.options[j].selected = true;
          break;
        }
      }
    }
  }
  var el = document.getElementById('disable-modal');
  if (el) new bootstrap.Modal(el).show();
})();
</script>
