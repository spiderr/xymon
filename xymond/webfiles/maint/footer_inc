<script>
Array.prototype.unique = function() {
  var r = [];
  outer: for (var i = 0, n = this.length; i < n; i++) {
    for (var x = 0, y = r.length; x < y; x++) { if (r[x] === this[i]) continue outer; }
    r[r.length] = this[i];
  }
  return r;
};
&JSHOSTLIST
function updateOptions() {
  var sel = window.document.selectionform.hostname;
  var chosen = [];
  for (var i = 0; i < sel.options.length; i++) {
    if (sel.options[i].selected) chosen.push(sel.options[i].text);
  }
  swapOptions(chosen);
}
function swapOptions(arrayNames) {
  var dt = window.document.selectionform.disabletest;
  while (dt.options.length > 0) dt.options[0] = null;
  var merged = [];
  for (var j = 0; j < arrayNames.length; j++) {
    if (hosts[arrayNames[j]]) merged = merged.concat(hosts[arrayNames[j]]);
  }
  merged = merged.unique();
  for (var i = 0; i < merged.length; i++) dt.options[i] = new Option(merged[i]);
}
function setcheck(field, val) {
  var len = field.length;
  if (len) { for (var i = 0; i < len; i++) field[i].checked = val; }
  else field.checked = val;
}
function ispositive(v) {
  var s = v.toString();
  for (var i = 0; i < s.length; i++) { if (s[i] < '0' || s[i] > '9') return false; }
  return parseInt(s, 10) >= 1;
}
function disableButtons(f, action) {
  for (var i = 0; i < f.length; i++) {
    if (f.elements[i].type.toLowerCase() === 'button') f.elements[i].disabled = action;
  }
}
function validateDisable(theform) {
  if (!theform.hostname.value) {
    alert('You must select the Host(s) to disable!');
    theform.hostname.focus();
    return false;
  }
  if (!theform.disabletest.value) {
    alert('You must select the Test(s) to disable!');
    theform.disabletest.focus();
    return false;
  }
  if (!theform.cause.value) {
    alert('You must fill in the Cause field!');
    theform.cause.focus();
    return false;
  }
  if (!ispositive(theform.duration.value)) {
    alert('Duration must be a positive integer.');
    return false;
  }
  var idx = theform.hostname.options.selectedIndex;
  if (idx >= 0 && theform.hostname.options[idx].value === 'ALL' &&
      !confirm('Do you really want to disable ALL Hosts? This could take a while.')) {
    return false;
  }
  disableButtons(theform, true);
  theform.submit();
}
</script>
