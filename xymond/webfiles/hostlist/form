<div class="card card-body mb-3">
  <form name="listparams" method="post" action="&SCRIPT_NAME">
    <input name="csvdelim" type="hidden" value=";">

    <div class="mb-3">
      <label class="form-label">Page</label>
      <input type="text" name="page" maxlength="80" value="&XYMWEBPAGEPATH" class="form-control">
    </div>

    <hr>

    <div class="mb-3">
      <div class="fw-semibold mb-2">Select</div>
      <div class="d-flex gap-4 flex-wrap">
        <div class="form-check">
          <input type="radio" name="filter" value="cpu" checked class="form-check-input" id="filter-cpu">
          <label class="form-check-label" for="filter-cpu">Hosts w/ client</label>
        </div>
        <div class="form-check">
          <input type="radio" name="filter" value="conn" class="form-check-input" id="filter-conn">
          <label class="form-check-label" for="filter-conn">Hosts w/ ping</label>
        </div>
        <div class="form-check">
          <input type="radio" name="filter" value="info" class="form-check-input" id="filter-info">
          <label class="form-check-label" for="filter-info">All hosts</label>
        </div>
      </div>
    </div>

    <hr>

    <div class="mb-3">
      <div class="fw-semibold mb-2">Include</div>
      <div class="row row-cols-auto g-2">
        <div class="col"><div class="form-check"><input name="XMH_PAGEPATH" type="checkbox" class="form-check-input" id="inc-pagepath"><label class="form-check-label" for="inc-pagepath">Page path</label></div></div>
        <div class="col"><div class="form-check"><input name="XMH_COMMENT" type="checkbox" class="form-check-input" id="inc-comment"><label class="form-check-label" for="inc-comment">Comment</label></div></div>
        <div class="col"><div class="form-check"><input name="XMH_DOWNTIME" type="checkbox" class="form-check-input" id="inc-downtime"><label class="form-check-label" for="inc-downtime">Downtime</label></div></div>
        <div class="col"><div class="form-check"><input name="XMH_NK" type="checkbox" class="form-check-input" id="inc-nk"><label class="form-check-label" for="inc-nk">NK columns</label></div></div>
        <div class="col"><div class="form-check"><input name="XMH_NKTIME" type="checkbox" class="form-check-input" id="inc-nktime"><label class="form-check-label" for="inc-nktime">NK time</label></div></div>
        <div class="col"><div class="form-check"><input name="XMH_REPORTTIME" type="checkbox" class="form-check-input" id="inc-reporttime"><label class="form-check-label" for="inc-reporttime">SLA period</label></div></div>
        <div class="col"><div class="form-check"><input name="XMH_WARNPCT" type="checkbox" class="form-check-input" id="inc-warnpct"><label class="form-check-label" for="inc-warnpct">SLA level</label></div></div>
        <div class="col"><div class="form-check"><input name="XMH_NET" type="checkbox" class="form-check-input" id="inc-net"><label class="form-check-label" for="inc-net">Network</label></div></div>
      </div>
    </div>

    <hr>
    <button type="submit" name="submit" value="Show" class="btn btn-primary">Show</button>
  </form>
</div>
