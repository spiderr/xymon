<div class="card card-body xymon-form-card">
  <form method="POST" action="&SCRIPT_NAME">
    <div class="row align-items-end xymon-field-row-tight">
      <div class="col-auto">
        <label class="form-label">Username</label>
        <input type="text" name="USERNAME" value="" maxlength="10" class="form-control">
      </div>
      <div class="col-auto">
        <label class="form-label">Password</label>
        <input type="text" name="PASSWORD" value="" maxlength="20" class="form-control">
      </div>
      <div class="col-auto">
        <button type="submit" name="SendCreate" value="Create" class="btn btn-primary">Create User</button>
      </div>
    </div>

    <hr>

    <div class="row align-items-end xymon-field-row-tight">
      <div class="col-auto">
        <label class="form-label">User</label>
        <select name="USERLIST" class="form-select">
          &GENERICLIST
        </select>
      </div>
      <div class="col-auto">
        <button type="submit" name="SendDelete" value="Delete" class="btn btn-danger">Delete User</button>
      </div>
    </div>
  </form>
</div>
