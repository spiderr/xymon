<div class="card card-body xymon-form-card">
  <form method="GET" action="&SCRIPT_NAME">
    <div class="row xymon-field-row">
      <div class="col-md-6">
        <label class="form-label">Hosts to match</label>
        <input type="text" name="HOST" class="form-control" placeholder="ex: ^host.*$">
      </div>
      <div class="col-md-6">
        <label class="form-label">Hosts to skip</label>
        <input type="text" name="EXHOST" class="form-control" placeholder="ex: ^host.*$">
      </div>
      <div class="col-md-6">
        <label class="form-label">Pages to match</label>
        <div class="input-group">
          <input type="text" name="PAGEMATCH" id="PAGEMATCH" class="form-control">
          <select name="PATHLIST" id="PATHLIST" class="form-select w-auto" onchange="document.getElementById('PAGEMATCH').value=document.getElementById('PATHLIST').value; return false">
            &PAGEPATH_DROPDOWN
          </select>
        </div>
      </div>
      <div class="col-md-6">
        <label class="form-label">Pages to skip</label>
        <input type="text" name="EXPAGEMATCH" class="form-control" placeholder="ex: ^webservers/.*$">
      </div>
      <div class="col-md-6">
        <label class="form-label">Start time <span class="text-muted small">(ex: 2009/01/15)</span></label>
        <input type="text" name="STARTTIME" id="STARTTIME" value="" class="form-control">
      </div>
      <div class="col-md-6">
        <label class="form-label">End time <span class="text-muted small">(ex: 2009/02/01)</span></label>
        <input type="text" name="ENDTIME" id="ENDTIME" value="" class="form-control">
      </div>
    </div>
    <div class="d-flex flex-wrap xymon-btn-row">
      <button type="button" class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('STARTTIME').value='&EVENTLASTMONTHBEGIN'; document.getElementById('ENDTIME').value='&EVENTCURRMONTHBEGIN'; return false">Last month</button>
      <button type="button" class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('STARTTIME').value='&EVENTCURRMONTHBEGIN'; document.getElementById('ENDTIME').value='&EVENTNOW'; return false">Current month</button>
      <button type="button" class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('STARTTIME').value='&EVENTLASTWEEKBEGIN'; document.getElementById('ENDTIME').value='&EVENTCURRWEEKBEGIN'; return false">Last week</button>
      <button type="button" class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('STARTTIME').value='&EVENTCURRWEEKBEGIN'; document.getElementById('ENDTIME').value='&EVENTNOW'; return false">Current week</button>
    </div>
    <div class="row xymon-field-row">
      <div class="col-md-4">
        <label class="form-label">Format</label>
        <select name="FORMAT" class="form-select w-auto">
          <option value=";" selected>CSV</option>
          <option value="XML">XML</option>
        </select>
      </div>
      <div class="col-md-6">
        <label class="form-label">Custom RRD filename</label>
        <input type="text" name="CUSTOMRRD" value="" class="form-control">
      </div>
      <div class="col-md-6">
        <label class="form-label">Custom dataset</label>
        <input type="text" name="CUSTOMDS" value="" class="form-control">
      </div>
    </div>
    <button type="submit" name="Send" value="View log" class="btn btn-primary">View log</button>
  </form>
</div>
